{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ConnectivityOutput",
  "description": "Connectivity check report produced by the connectivity agent",
  "type": "object",
  "required": ["valid", "issues", "stats", "format"],
  "properties": {
    "valid": {
      "type": "boolean",
      "description": "True if all connectivity checks passed"
    },
    "issues": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["severity", "code", "message"],
        "properties": {
          "severity": {
            "type": "string",
            "enum": ["error", "warning", "info"]
          },
          "code": {
            "type": "string",
            "description": "Machine-readable error code, e.g. DANGLING_NET, ORPHAN_NET"
          },
          "message": {
            "type": "string"
          },
          "net": {
            "type": "string"
          },
          "component": {
            "type": "string"
          },
          "pin": {
            "type": "integer"
          }
        },
        "additionalProperties": false
      }
    },
    "stats": {
      "type": "object",
      "required": ["net_count", "component_count", "connection_count", "error_count", "warning_count"],
      "properties": {
        "net_count": {"type": "integer"},
        "component_count": {"type": "integer"},
        "connection_count": {"type": "integer"},
        "error_count": {"type": "integer"},
        "warning_count": {"type": "integer"}
      },
      "additionalProperties": false
    },
    "format": {
      "type": "string",
      "enum": ["connectivity_report"]
    }
  },
  "additionalProperties": false
}
