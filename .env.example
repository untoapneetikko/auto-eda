# Copy this file to .env and fill in your values

# --- Cloudflare Tunnel ---
# Get this from: dash.cloudflare.com -> Zero Trust -> Networks -> Tunnels -> your tunnel -> token
CLOUDFLARE_TUNNEL_TOKEN=paste_your_token_here

# --- Claude Code auth path (Windows path) ---
# Default already correct for this machine - change if needed
CLAUDE_CONFIG_DIR=C:/Users/akiny/.claude
