{
  "permissions": {
    "allow": [
      "Bash(git clone:*)",
      "Bash(docker info:*)",
      "Bash(docker --version)",
      "Read(//usr/local/bin/**)",
      "Read(//opt/homebrew/bin/**)",
      "Bash(open -a \"Docker\" && echo \"started\")",
      "Bash(/Applications/Docker.app/Contents/Resources/bin/docker info:*)",
      "Bash(export DOCKER=/Applications/Docker.app/Contents/Resources/bin/docker\nexport COMPOSE=/Applications/Docker.app/Contents/Resources/bin/docker\n$DOCKER network ls | grep infra_net)",
      "Bash(DOCKER=/Applications/Docker.app/Contents/Resources/bin/docker; $DOCKER network ls | grep infra_net)",
      "Bash(/Applications/Docker.app/Contents/MacOS/uninstall --help 2>&1 | head -5)",
      "Bash(/Applications/Docker.app/Contents/MacOS/uninstall)",
      "Bash(sudo /Applications/Docker.app/Contents/MacOS/uninstall)",
      "Bash(docker network:*)",
      "Bash(docker compose:*)"
    ]
  }
}
